{% comment %} Blind Box Widget — App Block for Shopline Theme Editor {% endcomment %}

<div id="blind-box-app-block-{{ block.id }}" class="blind-box-widget-block">
  <iframe
    src="{{ block.settings.widget_url }}"
    style="width:100%;height:{{ block.settings.height }}px;border:none;border-radius:16px;"
    allow="payment *"
    loading="lazy"
    title="Blind Box Shop"
  ></iframe>
</div>

{% schema %}
{
  "name": "Blind Box Shop",
  "target": "section",
  "javascript": "blind-box-block.js",
  "settings": [
    {
      "type": "text",
      "id": "widget_url",
      "label": "Widget URL",
      "default": "https://blind-box-beta.vercel.app/widget",
      "info": "The URL of your Blind Box widget page."
    },
    {
      "type": "range",
      "id": "height",
      "label": "Widget height (px)",
      "min": 400,
      "max": 1200,
      "step": 50,
      "default": 700
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Blind Box Shop"
    }
  ],
  "presets": [
    {
      "name": "Blind Box Shop"
    }
  ]
}
{% endschema %}
